---
import Layout from "../layouts/layout.astro"
import RepeatedTextBG from "../components/RepeatedTextBG.tsx"

---

<Layout title="About" bgtext="自分">

	<!-- HERO -->
	<section class="border border-b-4 border-coffee bg-peach mb-8 overflow-hidden relative">
		<div class="absolute inset-0 z-0 opacity-5 pointer-events-none" style="background-image: repeating-radial-gradient(circle at 0% 0%, transparent 0, transparent 20px, #281b14 20px, #281b14 21px);"></div>
		<div class="relative z-10 flex flex-col lg:flex-row lg:items-stretch">
			<!-- Left: text -->
			<div class="flex-1 min-w-0 px-8 py-10 lg:py-14 flex flex-col justify-between gap-8">
				<div>
					<p class="hero-in hero-in-1 font-ibm text-xs tracking-widest uppercase text-coffee/50 mb-4">自分 — About Me</p>
					<h1 class="hero-in hero-in-2 font-archivo text-6xl sm:text-7xl lg:text-9xl tracking-tighter leading-none">
						Henry<br/>Stuklis
					</h1>
				</div>
				<div class="hero-in hero-in-3 flex flex-col gap-4">
					<div class="flex flex-wrap gap-2">
						<span class="font-ibm text-xs border border-coffee/30 px-2 py-1 text-coffee/60 tracking-wide">Senior Software Developer</span>
						<span class="font-ibm text-xs border border-coffee/30 px-2 py-1 text-coffee/60 tracking-wide">Data Engineer</span>
						<span class="font-ibm text-xs border border-coffee/30 px-2 py-1 text-coffee/60 tracking-wide">M.DataSc</span>
						<span class="font-ibm text-xs border border-coffee/30 px-2 py-1 text-coffee/60 tracking-wide">B.MathSc</span>
					</div>
					<blockquote class="border-l-4 border-coral pl-4">
						<p class="font-public-sans text-base lg:text-lg leading-relaxed text-coffee/80 max-w-lg">
							I build data systems and infrastructure at scale.
						</p>
					</blockquote>
				</div>
			</div>
			<!-- Right: photo -->
			<div class="hero-in hero-in-4 relative w-full lg:w-80 shrink-0 border-t lg:border-t-0 lg:border-l border-coffee overflow-hidden bg-bronze min-h-64 lg:min-h-0">
				<div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
					<RepeatedTextBG text="もしもし" classes="whitespace-nowrap select-none opacity-50 text-coffee text-sm tracking-tighter pointer-events-none">
					</RepeatedTextBG>
				</div>
				<img src="headshot.png" alt="Henry Stuklis" class="absolute inset-0 w-full h-full object-cover object-top z-10">
				<div class="absolute bottom-0 left-0 right-0 z-20 bg-coffee px-3 py-2">
					<p class="font-ibm text-xs text-peach/60 tracking-widest">hstuklis.dev</p>
				</div>
			</div>
		</div>
	</section>

	<!-- STATS STRIP -->
	<section class="border border-b-4 border-coffee bg-coffee text-peach mb-8 reveal">
		<div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-peach/10">
			<div class="px-6 py-5 flex flex-col gap-1">
				<p class="font-archivo text-3xl lg:text-4xl text-coral leading-none">5+</p>
				<p class="font-ibm text-xs tracking-widest text-peach/40 uppercase">Yrs. Experience</p>
			</div>
			<div class="px-6 py-5 flex flex-col gap-1">
				<p class="font-archivo text-3xl lg:text-4xl text-coral leading-none">Python</p>
				<p class="font-ibm text-xs tracking-widest text-peach/40 uppercase">& Java Stack</p>
			</div>
			<div class="px-6 py-5 flex flex-col gap-1 border-t lg:border-t-0 border-peach/10">
				<p class="font-archivo text-3xl lg:text-4xl text-coral leading-none">M.DataSc</p>
				<p class="font-ibm text-xs tracking-widest text-peach/40 uppercase">U. of Adelaide</p>
			</div>
			<div class="px-6 py-5 flex flex-col gap-1 border-t lg:border-t-0 border-peach/10">
				<p class="font-archivo text-3xl lg:text-4xl text-coral leading-none">Cloud</p>
				<p class="font-ibm text-xs tracking-widest text-peach/40 uppercase">AWS & Azure</p>
			</div>
		</div>
	</section>

	<!-- EXPERTISE -->
	<section class="border border-b-4 border-coffee bg-grey mb-8 reveal">
		<div class="px-8 py-10">
			<p class="font-ibm text-xs tracking-widest uppercase text-coffee/40 mb-1">専門 — Expertise</p>
			<h2 class="font-archivo text-4xl lg:text-5xl tracking-tighter mb-8">What I Do</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 border border-coffee/20">
				<div class="px-6 py-6 md:border-r border-coffee/20">
					<p class="font-ibm text-xs text-coffee/30 mb-3 tracking-widest">01</p>
					<h3 class="font-archivo text-xl mb-3">Data Engineering</h3>
					<p class="font-public-sans text-sm text-coffee/70 leading-relaxed">Most of my career has been about getting data from messy sources into something analysts can actually trust and use. At ABS I led ETL pipelines at national scale — including the Australian Immunisation Register weekly delivery as part of the COVID-19 statistical response. That same focus on reliability and traceability carries into everything I build now.</p>
				</div>
				<div class="px-6 py-6 border-t md:border-t-0 md:border-r border-coffee/20">
					<p class="font-ibm text-xs text-coffee/30 mb-3 tracking-widest">02</p>
					<h3 class="font-archivo text-xl mb-3">Software Engineering</h3>
					<p class="font-public-sans text-sm text-coffee/70 leading-relaxed">I've moved between Python and Java depending on what the job needs — PySpark pipelines on Azure, Spring Boot services on AWS, all containerised with Docker and Kubernetes. I care about owning the full lifecycle: good design up front, solid CI/CD, and code that someone else can actually maintain.</p>
				</div>
				<div class="px-6 py-6 border-t md:border-t-0 border-coffee/20">
					<p class="font-ibm text-xs text-coffee/30 mb-3 tracking-widest">03</p>
					<h3 class="font-archivo text-xl mb-3">Applied Mathematics</h3>
					<p class="font-public-sans text-sm text-coffee/70 leading-relaxed">A B.MathSc in Applied Mathematics and an M.DataSc gave me a way of thinking more than a set of facts. Breaking problems down rigorously, being comfortable with abstraction, knowing when a model is wrong — that background quietly shapes how I approach engineering problems.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="bg-mahogany text-coral border border-b-4 border-coral p-8 mb-8 reveal">
		<p class="font-ibm text-xs uppercase tracking-widest mb-3 text-coral/50">連絡 — Get In Touch</p>
		<h2 class="font-archivo text-4xl lg:text-5xl tracking-tighter mb-4">Let's Connect</h2>
		<p class="font-public-sans text-sm text-coral/80 mb-6 max-w-sm">Find me on GitHub or LinkedIn, or reach out directly if you're working on something interesting.</p>
		<div class="flex flex-wrap gap-3">
			<a
				href="mailto:henry.stuklis@gmail.com"
				class="inline-flex items-center gap-2 font-archivo text-sm border border-coral px-4 py-2 hover:bg-coral hover:text-mahogany transition-colors"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
				</svg>
				Email
			</a>
			<a
				href="https://www.linkedin.com/in/henry-stuklis/"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-2 font-archivo text-sm border border-coral px-4 py-2 hover:bg-coral hover:text-mahogany transition-colors"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
				</svg>
				LinkedIn
			</a>
			<a
				href="https://github.com/hstuklis"
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-2 font-archivo text-sm border border-coral px-4 py-2 hover:bg-coral hover:text-mahogany transition-colors"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.84 1.237 1.84 1.237 1.07 1.834 2.807 1.304 3.492.997.108-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.015 2.898-.015 3.293 0 .322.216.694.825.576C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/>
				</svg>
				GitHub
			</a>
		</div>
	</section>

</Layout>

<style>
	@keyframes heroIn {
		from {
			opacity: 0;
			transform: translateY(12px) scale(0.98);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}
	.hero-in {
		animation: heroIn 0.6s ease-out both;
	}
	.hero-in-1 { animation-delay: 0.05s; }
	.hero-in-2 { animation-delay: 0.15s; }
	.hero-in-3 { animation-delay: 0.28s; }

	@keyframes heroInFade {
		from { opacity: 0; }
		to   { opacity: 1; }
	}
	.hero-in-4 {
		animation: heroInFade 0.7s ease-out both;
		animation-delay: 0.38s;
	}

	.reveal {
		opacity: 0;
		transform: translateY(16px);
		transition: opacity 0.45s ease, transform 0.45s ease;
	}
	.reveal.visible {
		opacity: 1;
		transform: none;
	}
</style>

<script>
	const reveals = document.querySelectorAll('.reveal');
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry, i) => {
				if (entry.isIntersecting) {
					setTimeout(() => entry.target.classList.add('visible'), i * 80);
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.08 }
	);
	reveals.forEach(el => observer.observe(el));
</script>
