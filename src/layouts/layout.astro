---
import '../styles/global.css'
import Config from '~/config'
interface Props {
    title?: string
    description?: string
    tags?: string[]
    author?: string
}

const { title, description, tags, author } = Astro.props
const pageUrl = new URL(Astro.url.pathname, Astro.site).href.replace(/\/$/, '') 
const pageType = Astro.url.pathname.startsWith('/posts') ? 'post' : 'website'
const pageTitle = title ? `${title} » ${Config.title}` : Config.title
const pageDescription = description || Config.description
const pageAuthor = author || Config.author
const pageImage =
  pageType === 'post'
    ? Astro.url.origin +
      Astro.url.pathname.replace(/\/posts\//, '/social-cards/') +
      '.png'
    : `${Astro.url.origin}/social-cards/__default.png`
const pageKeywords = [
  ...new Set(Config.tags.concat(tags || []).map((word) => word.toLowerCase())),
].join(', ')
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
		<meta name="generator" content={Astro.generator} />
        <meta name="title" content={pageTitle} />
        <meta name="description" content={pageDescription} />
        <meta name="author" content={pageAuthor} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDescription} />
        <meta property="og:url" content={pageUrl} />
        <meta property="og:type" content={pageType} />
        {pageImage && <meta property="og:image" content={pageImage} />}
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={pageDescription} />
        {pageImage && <meta name="twitter:image" content={pageImage} />}
        <meta name="keywords" content={pageKeywords} />
        <link rel="canonical" href={pageUrl} />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <link
            rel="alternate"
            type="application/rss+xml"
            title={Config.title}
            href={new URL('rss.xml', Astro.site)}
        />
        <title>{pageTitle}</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.13.0/dist/katex.min.css">
    </head>
    <body class="mx-16 mb-8 mt-2 text-nb-fg-0 bg-nb-bg-0 font-public-sans">
        <div class="px-12 flex flex-col bg-nb-bg-1 border-8 border-nb-fg-0 border-t-32">
            <header>
                <nav class="flex flex-row flex-wrap justify-between items-end font-archivo my-4">
                    <h2 class="text-3xl"><a href="/" title="Home" class="hover:text-nb-blue">henstuk<a/>◈<a href="https://github.com/hstuklis" title="github.com/hstuklis" class="hover:text-nb-orange">dev<a/></h2>
                    <ul class="flex flex-row text-lg">
                        <li class="mr-2 hover:text-nb-blue"><a href="/about" title="About">About</a></li>
                        <li class="mr-2 hover:text-nb-blue"><a href="/posts" title="Posts">Posts</a></li>
                        <li class="mr-2">\\\</li>
                        <li><a class="hover:text-nb-pink" href="/wedding" title="🌹My Wedding Website🌹">Wedding</a></li>
                    </ul>
                </nav>
                <hr class="border-t-2">
            <header/>
            <main>
                <slot />
            </main>
        <div/>
    </body>
</html>