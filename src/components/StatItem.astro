---
interface Props {
  value: string;
  label: string;
}
const { value, label } = Astro.props;
---
<div class="px-3 sm:px-4 lg:px-6 py-5 flex flex-col gap-1">
  <p class="font-archivo text-2xl sm:text-3xl lg:text-4xl text-coral leading-none">{value}</p>
  <p class="font-ibm text-[10px] sm:text-xs tracking-normal sm:tracking-wide lg:tracking-widest text-peach/40 uppercase">{label}</p>
</div>
